{
  "hooks": [
    {
      "name": "rtk-bash",
      "tool": "bash",
      "when": "before",
      "transform": {
        "command": "rtk powershell.exe -NoProfile -Command \"{{command}}\""
      }
    },
    {
      "name": "rtk-powershell",
      "tool": "powershell",
      "when": "before",
      "transform": {
        "command": "rtk powershell.exe -NoProfile -Command \"{{command}}\""
      }
    }
  ]
}
